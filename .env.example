# Copy to .env and fill in values. Never commit .env.

FLASK_ENV=development
# FLASK_DEBUG=1
SECRET_KEY=

# OAuth (required in production)
FITBIT_CLIENT_ID=
FITBIT_CLIENT_SECRET=
REDIRECT_URI=http://127.0.0.1:3000/callback

# Comma-separated browser origins (required when FLASK_ENV=production)
# ALLOWED_ORIGINS=https://your-vitals7-domain.com,https://www.your-vitals7-domain.com

# Optional: DATABASE_URL defaults to sqlite instance
# DATABASE_URL=postgresql+psycopg2://user:pass@host:5432/dbname

# AWS (DynamoDB user_vitals + vitals-di-tokens)
AWS_REGION=us-east-1
# Prefer IAM role in production; keys only for local dev if needed
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=

# Fitbit Subscription API — required for push → user_vitals (no server-side polling).
# 1) In https://dev.fitbit.com/apps set Subscriber URL to public HTTPS:
#    https://<your-host>/api/fitbit/webhook  (format: JSON, TLS 1.2+)
# 2) Paste the verification code shown next to "Verify" into .env, then click Verify in the portal.
FITBIT_SUBSCRIBER_VERIFICATION_CODE=
# Optional if you use a non-default subscriber row in the Fitbit app:
# FITBIT_SUBSCRIBER_ID=

# Realtime gateway (production: set URL and a strong shared secret)
# VITALS_REALTIME_GATEWAY_URL=
# VITALS_REALTIME_GATEWAY_SECRET=

# Behind reverse proxy (nginx, ALB)
# TRUST_PROXY_HEADERS=1

# Production-only toggles (see app/config.py for defaults)
# SESSION_COOKIE_SECURE=1
# SESSION_COOKIE_SAMESITE=Lax
# ENABLE_DOCS=0
# ENABLE_DEBUG_DB_VIEWS=0

# Gunicorn (production)
# BIND=0.0.0.0:3000
# WEB_CONCURRENCY=1
# PORT=3000
# HOST=127.0.0.1
